class math {
    def add(int a, int b) {
        return a + b;
    }
    def sub(int a, int b) {
        return a - b;
    }
    def mul(int a, int b) {
        return a * b;
    }
    def div(int a, int b) {
        return a / b;
    }
    def mod(int a, int b) {
        return a % b;
    }
}
